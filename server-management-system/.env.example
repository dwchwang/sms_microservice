# ============================================
# VCS-SMS Environment Configuration (v2)
# ============================================

# ── PostgreSQL ──
POSTGRES_USER=vcs_admin
POSTGRES_PASSWORD=postgres_secret
POSTGRES_DB=vcs_sms
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ──
REDIS_PASSWORD=redis_secret
REDIS_HOST=redis
REDIS_PORT=6379

# ── Elasticsearch ──
ES_HOST=elasticsearch
ES_ADDRESSES=http://elasticsearch:9200
ES_PORT=9200
ES_INDEX_NAME=server-status-logs

# ── Service Ports ──
GATEWAY_PORT=8080
AUTH_PORT=8081
SERVER_PORT=8082
MONITOR_PORT=8083
REPORT_PORT=8084
FILEIO_PORT=8085

# ── JWT ──
JWT_SECRET=change-me-to-a-random-64-char-string-in-production
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ── SMTP (Gmail) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=VCS-SMS <your-email@gmail.com>
SMTP_ADMIN_EMAIL=admin@company.com

# ── Monitor Service ──
MONITOR_WORKER_COUNT=100
MONITOR_CHECK_INTERVAL=60
MONITOR_TCP_TIMEOUT=5000
MONITOR_CHECK_INTERVAL_SECONDS=60
MONITOR_TCP_TIMEOUT_MS=5000

# ── TCP Simulator ──
SIMULATOR_BASE_PORT=9001
SIMULATOR_NUM_SERVERS=10000
SIMULATOR_TICK_INTERVAL=30s
SIMULATOR_DEFAULT_UPTIME_RATE=0.95

# ── Database Connection Strings (v2) ──
# Identity Service DB (formerly Auth)
IDENTITY_DB_HOST=postgres
IDENTITY_DB_PORT=5432
IDENTITY_DB_USER=identity_user
IDENTITY_DB_PASSWORD=identity_pass_secret
IDENTITY_DB_NAME=identity_db
IDENTITY_DB_SSLMODE=disable

# Server Service DB
SERVER_DB_HOST=postgres
SERVER_DB_PORT=5432
SERVER_DB_USER=server_user_v2
SERVER_DB_PASSWORD=server_pass_secret_v2
SERVER_DB_NAME=server_db
SERVER_DB_SSLMODE=disable

# Report Service DB
REPORT_DB_HOST=postgres
REPORT_DB_PORT=5432
REPORT_DB_USER=report_user_v2
REPORT_DB_PASSWORD=report_pass_secret_v2
REPORT_DB_NAME=report_db
REPORT_DB_SSLMODE=disable

# ── FileIO Upload Config (Temporary until removed) ──
FILEIO_UPLOAD_DIR=/app/uploads
FILEIO_MAX_FILE_SIZE_MB=10

# ── Logging ──
LOG_LEVEL=info
LOG_DIR=/var/log/vcs-sms
LOG_MAX_SIZE_MB=100
LOG_MAX_BACKUPS=5
LOG_MAX_AGE_DAYS=30
LOG_COMPRESS=true
