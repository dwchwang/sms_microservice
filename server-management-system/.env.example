# ============================================
# VCS-SMS Environment Configuration
# ============================================

# ── PostgreSQL ──
POSTGRES_USER=vcs_admin
POSTGRES_PASSWORD=postgres_secret
POSTGRES_DB=vcs_sms
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Redis ──
REDIS_PASSWORD=redis_secret
REDIS_HOST=redis
REDIS_PORT=6379

# ── Elasticsearch ──
ES_HOST=elasticsearch
ES_ADDRESSES=http://elasticsearch:9200
ES_PORT=9200
ES_INDEX_NAME=server-status-logs

# ── Kafka ──
KAFKA_BROKERS=kafka:29092
KAFKA_PORT=9092

# ── Service Ports ──
GATEWAY_PORT=8080
AUTH_PORT=8081
SERVER_PORT=8082
MONITOR_PORT=8083
REPORT_PORT=8084
FILEIO_PORT=8085

# ── Gateway Upstream URLs (Docker service names) ──
AUTH_SERVICE_URL=http://auth-service:8081
SERVER_SERVICE_URL=http://server-service:8082
MONITOR_SERVICE_URL=http://monitor-service:8083
REPORT_SERVICE_URL=http://report-service:8084
FILEIO_SERVICE_URL=http://fileio-service:8085

# ── JWT ──
JWT_SECRET=change-me-to-a-random-64-char-string-in-production
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ── SMTP (Gmail) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM=VCS-SMS <your-email@gmail.com>
SMTP_ADMIN_EMAIL=admin@company.com

# ── Monitor Service ──
MONITOR_WORKER_COUNT=100
MONITOR_CHECK_INTERVAL=60
MONITOR_TCP_TIMEOUT=5000
MONITOR_CHECK_INTERVAL_SECONDS=60
MONITOR_TCP_TIMEOUT_MS=5000

# ── TCP Simulator ──
SIMULATOR_BASE_PORT=9001
SIMULATOR_NUM_SERVERS=10000
SIMULATOR_TICK_INTERVAL=30s
SIMULATOR_DEFAULT_UPTIME_RATE=0.95

# ── Database Connection Strings (per service) ──
# Auth Service DB
AUTH_DB_HOST=postgres
AUTH_DB_PORT=5432
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=auth_pass_secret
AUTH_DB_NAME=vcs_sms
AUTH_DB_SCHEMA=auth_schema

# Server Service DB
SERVER_DB_HOST=postgres
SERVER_DB_PORT=5432
SERVER_DB_USER=server_user
SERVER_DB_PASSWORD=server_pass_secret
SERVER_DB_NAME=vcs_sms
SERVER_DB_SCHEMA=server_schema

# Monitor Service DB
MONITOR_DB_HOST=postgres
MONITOR_DB_PORT=5432
MONITOR_DB_USER=monitor_user
MONITOR_DB_PASSWORD=monitor_pass_secret
MONITOR_DB_NAME=vcs_sms
MONITOR_DB_SCHEMA=monitor_schema

# Report Service DB
REPORT_DB_HOST=postgres
REPORT_DB_PORT=5432
REPORT_DB_USER=report_user
REPORT_DB_PASSWORD=report_pass_secret
REPORT_DB_NAME=vcs_sms
REPORT_DB_SCHEMA=report_schema

# FileIO Service DB
FILEIO_DB_HOST=postgres
FILEIO_DB_PORT=5432
FILEIO_DB_USER=fileio_user
FILEIO_DB_PASSWORD=fileio_pass_secret
FILEIO_DB_NAME=vcs_sms
FILEIO_DB_SCHEMA=fileio_schema
FILEIO_DB_SSLMODE=disable

# FileIO Upload Config
FILEIO_UPLOAD_DIR=/app/uploads
FILEIO_MAX_FILE_SIZE_MB=10

# Cross-schema: FileIO → server_schema (read/write servers table)
SERVER_DB_HOST=postgres
SERVER_DB_PORT=5432
SERVER_DB_USER=server_user
SERVER_DB_PASSWORD=server_pass_secret
SERVER_DB_NAME=vcs_sms
SERVER_DB_SCHEMA=server_schema
SERVER_DB_SSLMODE=disable

# ── Logging ──
LOG_LEVEL=info
LOG_DIR=/var/log/vcs-sms
LOG_MAX_SIZE_MB=100
LOG_MAX_BACKUPS=5
LOG_MAX_AGE_DAYS=30
LOG_COMPRESS=true
